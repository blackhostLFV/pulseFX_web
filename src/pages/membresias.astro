<style>
/* ===== Membresías — adiciones de página (namespaced) ===== */
.mhero{padding:72px 0 30px}
.mhero .container{position:relative;z-index:2}
.mhero .eyebrow{display:inline-block;margin-bottom:16px}
.mhero h1{font-size:clamp(40px,5.4vw,70px);font-weight:800;text-align:center}.mhero h1 .ac{color:var(--blue-l)}
.mhero .lead{font-size:18px;color:#9AA3B2;margin:22px auto 30px;max-width:600px;text-align:center}
.mhero .hero-cta{justify-content:center}
/* hero — par de cards flotantes (Silver/Gold) */
.mfan{position:relative;height:430px;margin-top:46px;display:flex;align-items:center;justify-content:center;perspective:1400px}
.mfcard{position:absolute;left:50%;width:300px;border-radius:24px;padding:26px;border:1px solid}
.mfcard .nm{font-weight:800;font-size:22px;letter-spacing:-.02em}
.mfcard .pr{font-size:34px;font-weight:800;margin-top:8px}.mfcard .pr span{font-size:13px;font-weight:600;opacity:.55}
.mfcard .bn{margin-top:14px;font-size:12px;font-weight:700;border-radius:11px;padding:10px 13px}
.mfcard ul{list-style:none;margin-top:16px;display:flex;flex-direction:column;gap:9px}
.mfcard li{display:flex;gap:9px;align-items:center;font-size:12.5px;font-weight:600}
.mfcard li i{width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex:0 0 auto}
.mfcard li i svg{width:9px;height:9px;stroke-width:3;stroke-linecap:round;stroke-linejoin:round;fill:none}
.mfcard.silver{transform:translateX(-96%) rotate(-7deg);background:rgba(255,255,255,.94);border-color:#E7E9EE;color:#0E1116;box-shadow:0 32px 70px -28px rgba(20,35,70,.6);z-index:1}
.mfcard.silver .bn{background:var(--soft);color:var(--blue)}
.mfcard.silver li i{background:#EAF0F9;color:var(--blue)}.mfcard.silver li i svg{stroke:var(--blue)}
.mfcard.gold{transform:translateX(-4%) rotate(5deg) translateY(-16px);background:#0E1116;border-color:rgba(255,255,255,.1);color:#fff;box-shadow:0 42px 90px -30px rgba(0,0,0,.72);z-index:2}
.mfcard.gold .pr span{color:rgba(255,255,255,.55)}
.mfcard.gold .bn{background:linear-gradient(135deg,rgba(232,184,59,.2),rgba(201,145,42,.12));color:#F0C75A;border:1px solid rgba(232,184,59,.3)}
.mfcard.gold li i{background:rgba(46,114,240,.25);color:var(--blue-l)}.mfcard.gold li i svg{stroke:var(--blue-l)}
.mfcard .tag{position:absolute;top:-11px;right:20px;font-size:10px;font-weight:800;letter-spacing:.07em;padding:5px 11px;border-radius:999px;background:var(--blue);color:#fff}
/* (.plan-bonus y .plan .ck svg ahora viven en pulsefx.css, compartidos con el home) */
.plans-note{text-align:center;max-width:660px;margin:30px auto 0;font-size:13px;color:var(--ink3);line-height:1.6}
/* cards de beneficio con micro-UI */
.bgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.bcard{padding:26px 24px;display:flex;flex-direction:column}
.bcard .bh{display:flex;align-items:center;gap:13px;margin-bottom:8px}
.bcard .bt-ic{width:44px;height:44px;border-radius:13px;background:var(--soft);border:1px solid rgba(46,114,240,.2);display:flex;align-items:center;justify-content:center;flex:0 0 auto;color:var(--blue)}
.dark .bcard .bt-ic{color:var(--blue-l)}
.bcard .bt-ic svg{width:21px;height:21px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.bcard h3{font-size:17px;font-weight:800;color:var(--ink)}
.bcard .bd{font-size:13.5px;color:var(--ink2);margin:0 0 20px;line-height:1.5}
.bcard .viz-wrap{margin-top:auto}
.cui-bal{width:100%;border-radius:14px;padding:16px;background:linear-gradient(140deg,var(--azure),var(--blue-d));color:#fff;position:relative;overflow:hidden}
.cui-bal .g{position:absolute;width:120px;height:120px;border-radius:50%;background:rgba(255,255,255,.16);right:-36px;top:-44px}
.cui-bal .l{font-size:10px;opacity:.85;font-weight:600;position:relative}
.cui-bal .v{font-size:26px;font-weight:800;margin-top:3px;position:relative}
.cui-bal .c{display:inline-block;margin-top:9px;font-size:10.5px;font-weight:700;background:rgba(255,255,255,.22);padding:3px 9px;border-radius:7px;position:relative}
.cui-bal .sm{font-size:10.5px;opacity:.85;margin-top:10px;position:relative}
/* comparativa */
.cmp{border:1px solid var(--bd);border-radius:24px;overflow:hidden;background:var(--panel);max-width:900px;margin:0 auto;box-shadow:var(--sh)}
.cmp .crow{display:grid;grid-template-columns:1.5fr 1fr 1fr;align-items:center}
.cmp .crow + .crow{border-top:1px solid var(--bd)}
.cmp .crow.h{background:rgba(255,255,255,.03)}
.light .cmp .crow.h{background:#F4F6F9}
.cmp .cc{padding:16px 22px;font-size:14px;color:var(--ink2);text-align:center}
.cmp .cc.lab{text-align:left;font-weight:700;color:var(--ink)}
.cmp .crow.h .cc{font-weight:800;color:var(--ink);font-size:15px}
.cmp .cc.g{background:rgba(46,114,240,.06)}
.dark .cmp .cc.g{background:rgba(46,114,240,.1)}
.cmp .crow.h .cc.g{color:var(--blue-l)}.light .cmp .crow.h .cc.g{color:var(--blue)}
.cmp .gbadge{font-size:9px;font-weight:800;background:var(--blue);color:#fff;padding:3px 8px;border-radius:999px;margin-left:7px;vertical-align:middle;letter-spacing:.04em}
.cmp .cc b{color:var(--ink);font-weight:800}
/* pasos */
.msteps{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.mstep{padding:26px 24px;position:relative}
.mstep .no{font-size:13px;font-weight:800;color:var(--blue);letter-spacing:.06em}.dark .mstep .no{color:var(--blue-l)}
.mstep .mi{width:46px;height:46px;border-radius:13px;background:var(--soft);display:flex;align-items:center;justify-content:center;color:var(--blue);margin:14px 0 16px}.dark .mstep .mi{color:var(--blue-l)}
.mstep .mi svg{width:23px;height:23px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.mstep h4{font-size:16px;font-weight:800;color:var(--ink)}
.mstep p{font-size:13px;color:var(--ink2);margin-top:7px;line-height:1.5}
@media(max-width:960px){.bgrid,.msteps{grid-template-columns:1fr 1fr}.mfan{transform:scale(.92)}}
@media(max-width:600px){
  .bgrid,.msteps{grid-template-columns:1fr}
  .cmp .cc{padding:13px 12px;font-size:12.5px}.cmp .cc.lab{padding-left:16px}
  .mfan{height:auto;flex-direction:column;gap:20px;perspective:none;margin-top:40px}
  .mfcard{position:static;transform:none;width:100%;max-width:330px}
}
</style>
